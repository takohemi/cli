{
  "name": "@takohemi/cli",
  "version": "0.1.4",
  "description": "Takohemi — Opinionated project scaffolding CLI with plugin architecture",
  "type": "module",
  "bin": {
    "takohemi": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "scaffolding",
    "boilerplate",
    "react",
    "nextjs",
    "typescript",
    "takohemi"
  ],
  "author": "Takohemi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/takohemi/cli.git"
  },
  "homepage": "https://github.com/takohemi/cli#readme",
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "degit": "^2.8.4",
    "execa": "^9.5.2",
    "fs-extra": "^11.2.0",
    "handlebars": "^4.7.8",
    "ora": "^8.1.1",
    "prompts": "^2.4.2",
    "semver": "^7.6.3"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.0",
    "@types/prompts": "^2.4.9",
    "eslint": "^9.16.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.56.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "templates"
  ]
}
